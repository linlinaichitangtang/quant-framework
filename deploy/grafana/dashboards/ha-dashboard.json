{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "集群节点状态",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "count(up{job=\"openclaw-backend\"} == 1)", "legendFormat": "在线节点" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "title": "QPS (每秒请求数)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"openclaw-backend\"}[5m]))",
          "legendFormat": "QPS"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "title": "请求延迟 (P50/P95/P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(http_request_duration_seconds_bucket{job=\"openclaw-backend\"}[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"openclaw-backend\"}[5m])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"openclaw-backend\"}[5m])) by (le))", "legendFormat": "P99" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "title": "错误率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"openclaw-backend\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"openclaw-backend\"}[5m])) * 100",
          "legendFormat": "5xx 错误率"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "title": "数据库复制延迟",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "mysql_slave_seconds_behind_master",
          "legendFormat": "复制延迟"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "s",
          "min": 0,
          "max": 60
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "活跃告警",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "ALERTS{alertstate=\"firing\"}", "legendFormat": "{{alertname}}" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" } },
        "overrides": []
      },
      "options": { "showHeader": true }
    },
    {
      "title": "系统资源使用率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "avg(process_resident_memory_bytes{job=\"openclaw-backend\"}) / 1024 / 1024", "legendFormat": "内存 (MB)" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "color": { "mode": "thresholds" } },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["openclaw", "ha", "monitoring"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "options": []
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenClaw 高可用监控",
  "uid": "openclaw-ha-dashboard",
  "version": 1
}
