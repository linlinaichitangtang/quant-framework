# ===========================================
# OpenClaw量化交易框架 环境变量配置
# 复制此文件为 .env 并填写实际值
# ===========================================

# ========== 数据库配置 ==========
MYSQL_ROOT_PASSWORD=quant123456
MYSQL_DATABASE=quant_trade
MYSQL_USER=quant
MYSQL_PASSWORD=quant123456
# 后端数据库连接（SQLite用于开发，MySQL用于生产）
DATABASE_URL=sqlite:///./quant_trade.db
# DATABASE_URL=mysql+pymysql://quant:quant123456@db:3306/quant_trade

# ========== 应用配置 ==========
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# ========== 数据源 Token ==========
# AKShare不需要token
AK_SHARE_TOKEN=
# Tushare需要注册获取: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# ========== FMZ发明者量化配置 ==========
FMZ_API_KEY=your_fmz_api_key
FMZ_SECRET_KEY=your_fmz_secret_key
FMZ_CID=your_fmz_cid

# ========== 定时任务 Cron 表达式（分 时 日 月 周）==========
A_STOCK_COLLECT_CRON=15 15 * * 1-5
HK_STOCK_COLLECT_CRON=16 16 * * 1-5
US_STOCK_COLLECT_CRON=0 5 * * 2-6

# ========== CORS 配置 ==========
# 生产环境填写实际域名，多个用逗号分隔
CORS_ORIGIN=https://your-domain.com
# 开发环境可使用通配符
# CORS_ORIGIN=*
