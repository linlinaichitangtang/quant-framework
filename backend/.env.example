# 数据库配置
# SQLite:
DATABASE_URL=sqlite:///./quant_trade.db
# MySQL:
# DATABASE_URL=mysql+pymysql://username:password@host:port/quant_trade

# API配置
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# 数据采集配置
# AKShare不需要token，使用Tushare请填写
TUSHARE_TOKEN=

# FMZ API配置
FMZ_API_KEY=your_fmz_api_key
FMZ_SECRET_KEY=your_fmz_secret_key
FMZ_CID=your_fmz_cid

# 定时任务Cron表达式（分 时 日 月 周）
A_STOCK_COLLECT_CRON=15 15 * * 1-5
HK_STOCK_COLLECT_CRON=16 16 * * 1-5
US_STOCK_COLLECT_CRON=0 5 * * 2-6
